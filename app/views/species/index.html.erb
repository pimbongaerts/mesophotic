<%= render partial: "layouts/page_title",
       	   locals: {title: "Species",
            		breadcrumbs: [["Species", nil]] } %>

<div class="row">
  <div class="col-sm-12">
    <div class="accordion" id="species_accordion">
      <% @focusgroups.each do |focusgroup| %>
        <%= render partial: 'specieslist',
                   locals: { focusgroup: focusgroup,
                             species_list: @species.where(focusgroup: focusgroup)} %>
      <% end %>
    </div>
  </div>
</div>