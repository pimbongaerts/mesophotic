<div class="col-sm-6">
  <div class="card h-100">
    <div class="card-img-top" style="aspect-ratio: 3/2; overflow: hidden; background-color: #f0f1f3;">
      <% if (post.post_type == "behind_the_science" || post.post_type == "early_career") && post.photos.count >= 4 %>
        <%= link_to post_pages_path(post), style: "text-decoration: none;" do %>
          <div class="row g-1 p-1 h-100">
            <% post.photos[0..3].each_slice(2).each do |row| %>
              <% row.each do |photo| %>
                <div class="col-6">
                  <%= image_tag photo.image.variant(resize: "300x200^", crop: "300x200+0+0"),
                                class: "img-fluid rounded-1", style: "width: 100%; height: 100%; object-fit: cover;" %>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      <% elsif post.photos.present? %>
        <%= link_to post_pages_path(post) do %>
          <%= image_tag post.photos[0].image.variant(resize: "600x400^", crop: "600x400+0+0"),
                        style: "width: 100%; height: 100%; object-fit: cover;" %>
        <% end %>
      <% end %>
    </div>
    <div class="card-body">
      <p class="text-muted mb-1"><small><%= post.category %></small></p>
      <h5 class="card-title">
        <%= link_to post.title, post_pages_path(post.slug), style: "text-decoration: none; color: inherit;" %>
      </h5>
    </div>
  </div>
</div>
