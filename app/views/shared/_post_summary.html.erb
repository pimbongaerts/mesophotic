<div class="card mb-4">
  <div class="row g-0">
    <% if (post.post_type == "behind_the_science" || post.post_type == "early_career") && post.photos.count >= 6 %>
      <div class="col-sm-4" style="aspect-ratio: 9/4; overflow: hidden; background-color: #f0f1f3;">
        <%= link_to post_pages_path(post), style: "text-decoration: none;" do %>
          <div class="row g-1 p-1 h-100">
            <% post.photos[0..5].each do |photo| %>
              <div class="col-4">
                <%= image_tag photo.image.variant(resize: "150x100^", crop: "150x100+0+0"),
                              class: "img-fluid rounded-1", style: "width: 100%; height: 100%; object-fit: cover;" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% elsif post.photos.present? %>
      <div class="col-sm-4" style="aspect-ratio: 3/2; overflow: hidden; background-color: #f0f1f3;">
        <%= link_to post_pages_path(post) do %>
          <%= image_tag post.photos[0].image.variant(resize: "600x400^", crop: "600x400+0+0"),
                        class: "img-fluid rounded-start", style: "width: 100%; height: 100%; object-fit: cover;" %>
        <% end %>
      </div>
    <% else %>
      <div class="col-sm-4" style="background-color: #f0f1f3;"></div>
    <% end %>
    <div class="col-sm-8">
      <div class="card-body">
        <p class="text-muted mb-1">
          <small><%= post.category %></small>
          <small class="ms-2"><i class="bi bi-calendar3"></i> <%= post.created_at.strftime("%B %-d, %Y") %></small>
        </p>
        <h5 class="card-title">
          <%= link_to post.title, post_pages_path(post.slug), style: "text-decoration: none; color: inherit;" %>
        </h5>
        <p class="card-text" style="font-size: 0.9em;">
          <% if post.post_type == "behind_the_science" &&
                post.featured_user.present? &&
                post.featured_publication.present? %>
            An interview with
            <%= link_to post.featured_user.full_name_normal, member_pages_path(post.featured_user) %>
            about their article "<%= post.featured_publication.title_truncated %>".
          <% elsif post.post_type == "early_career" &&
                   post.featured_user.present? %>
            An interview with
            <%= link_to post.featured_user.full_name_normal, member_pages_path(post.featured_user) %>
            about their research and experiences.
          <% end %>
        </p>
        <% if post.user.present? %>
          <p class="card-text">
            <small class="text-muted">
              Posted by <%= link_to post.user.full_name_normal, member_pages_path(post.user) %>
            </small>
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>
