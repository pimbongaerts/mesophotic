<div class="row">
  <% plain_title = defined?(page_title) && page_title.present? ? page_title : title %>
  <% if defined?(subtitle) && subtitle.present? %>
    <% title("#{strip_tags(plain_title)}: #{strip_tags(subtitle)}") %>
  <% else %>
    <% title("#{strip_tags(plain_title)}") %>
  <% end %>
</div>

<% if defined?(breadcrumbs) && breadcrumbs.present? %>
  <%= render partial: 'shared/breadcrumbs', locals: { breadcrumbs: breadcrumbs } %>
<% end %>

<div class="row">
  <div class="col-12">
    <% if defined?(supertitle) && supertitle.present? %>
      <small class="text-muted text-uppercase" style="letter-spacing: 0.05em;"><%= supertitle %></small>
    <% end %>
    <h3 class="page-title">
      <%= title %><% if defined?(subtitle) && subtitle.present? %> <span style="font-weight: normal; font-size: 0.75em;" class="text-muted"><%= subtitle %></span><% end %>
    </h3>
  </div>
</div>
