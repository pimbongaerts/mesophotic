<div class="row">
  <% if defined?(title) && defined?(subtitle) %>
    <% title("#{title}: #{subtitle}") %>
  <% else %>
    <% title("#{title}") %>
  <% end %>
</div>

<div class="row">
  <div class="col-10">
    <h3 class="page-title">
      <%= title %>:
      <% if defined?(subtitle) %>
      <br><small><%= subtitle %></small>
      <% end %>
    </h3>
  </div>
  <div class="col-2">
    <% if backlink %>
      <h3 class="page-title text-end">
        <%= link_to '<<< back', backlink, style: "font-size: 0.58em; text-decoration: none;" %>
      </h3>
    <% end %>
  </div>
</div>
