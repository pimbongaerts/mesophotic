<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= @title || "Mesophotic" %></title>

  <%= favicon_link_tag 'favicon.ico' %>
  <%= favicon_link_tag 'apple-icon.png', rel: 'apple-touch-icon', type: 'image/png' %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "bootstrap-icons", "data-turbo-track": "reload" %>

  <%= javascript_importmap_tags %>
  <%= javascript_include_tag "popper", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "bootstrap", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "dual_range", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "wordcloud2", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "charts", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "feed_tabs", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "tom-select-rails/js/tom-select.complete.min", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "tom_select_init", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "image_drop", "data-turbo-track": "reload" %>
  <%= yield :head %>
  <%= javascript_include_tag "proj4", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "highcharts", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "highcharts-more", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "highcharts-exporting", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "highcharts-export-data", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "highcharts-map", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "highcharts-world-continents", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "highcharts-accessibility", "data-turbo-track": "reload" %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
</head>
<body>
  <div id="wrap">
    <%= render 'layouts/navigation' %>

    <div class="container">
      <div class="row">
        <div class="col-sm-6 offset-sm-3 text-center">
          <%= render 'layouts/messages' %>
        </div>
      </div>

      <div class="row">
        <div class="col-sm-12">
          <%= yield %>
        </div>
      </div>
    </div>

  </div>

<%= render 'layouts/footer' %>
	<%= debug(params) if Rails.env.development? %>
</body>
</html>
