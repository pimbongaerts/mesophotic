<div class="card mb-0 h-100 d-flex flex-column">
  <div class="card-header"><strong>Featured location</strong></div>
  <div style="aspect-ratio: 4/3; overflow: hidden; background-color: #f0f1f3;">
    <%= link_to location_path(@featured_location) do %>
      <%= image_tag @featured_photo.image.variant(resize: "400x300^", crop: "400x300+0+0"),
                    style: "width: 100%; height: 100%; object-fit: cover;" %>
    <% end %>
  </div>
  <div class="card-footer text-center flex-grow-1">
    <%= link_to @featured_location.description, location_path(@featured_location),
                style: "text-decoration: none;" %>
    <% if @featured_photo.credit.present? %>
      <br><small class="text-muted">&copy; <%= @featured_photo.credit %></small>
    <% end %>
  </div>
</div>
