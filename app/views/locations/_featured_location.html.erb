<div class="card">
  <div class="card-header"><strong>Featured location</strong></div>
  <div class="card-body" align="center">
    <%= link_to image_tag(@featured_photo.image.variant(resize: "340x227^", crop: "340x227+0+0")), 
                location_path(@featured_location) %>
    
  </div>
  <div class="card-footer" align="center">
    <%= link_to @featured_location.description, location_path(@featured_location) %>
  </div>
</div>
