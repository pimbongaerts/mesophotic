<%# Profile %>
<div class="card">
  <div class="card-header">
    <strong>User Profile</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-6">
        <div class="row">
          <div class="col-4">
            <div class="mb-3">
              <%= f.label :title, class: 'required' %><br>
              <%= f.select :title, User::TITLES,
                           { prompt: "Title..." },
                           { class: "form-select" } %>
            </div>
          </div>
        </div>
        <div class="mb-3">
          <%= f.label :first_name, class: 'required' %><br>
          <%= f.text_field :first_name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :last_name, class: 'required' %><br>
          <%= f.text_field :last_name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :email , class: 'required' %><br>
          <%= f.email_field :email, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :mastodon_handle, "Mastodon" %>
          <small>(e.g. @user@mastodon.social)</small><br>
          <%= f.text_field :mastodon_handle, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :bluesky_handle, "Bluesky" %>
          <small>(e.g. mesophotic.bsky.social)</small><br>
          <%= f.text_field :bluesky_handle, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :threads_handle, "Threads" %>
          <small>(e.g. @mesophotic)</small><br>
          <%= f.text_field :threads_handle, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :twitter_handle, "Twitter / X" %>
          <small>(e.g. @mesophotic)</small><br>
          <%= f.text_field :twitter_handle, class: "form-control" %>
        </div>
      </div>
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :profile_picture, class: 'required' %><br>
          <div data-image-drop="user_profile_picture"
               class="rounded-3 mb-2 d-flex align-items-center justify-content-center"
               style="aspect-ratio: 1/1; height: 352px; border: 2px dashed #dee2e6; cursor: pointer; overflow: hidden; background-color: #f8f9fa; position: relative; transition: all 0.15s ease;">
            <% if @user.profile_picture.attached? %>
              <%= image_tag @user.profile_picture.variant(resize: "300x300^", crop: "300x300+0+0"),
                            data: { image_drop_preview: true },
                            style: "position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;" %>
            <% else %>
              <div data-image-drop-placeholder class="text-center text-muted">
                <i class="bi bi-cloud-arrow-up" style="font-size: 2rem;"></i>
                <br><small>Drop image or click</small>
              </div>
              <img data-image-drop-preview style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; display: none;">
            <% end %>
          </div>
          <%= f.file_field :profile_picture, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Affiliations %>
<div class="card">
  <div class="card-header">
    <strong>User Affiliations</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-7">
        <div class="mb-3">
          <%= f.label :organisation_id %>
          <small>
            (primary organisation that you are affiliated with)
          </small>
          <br>
          <%= f.collection_select :organisation_id,
                                  Organisation.find_each,
                                  :id, :name,
                                  class: "form-control",
                                  :prompt => "Organisation..." %>
        </div>
        <div class="mb-3">
          <%= f.label :department %>
          <small>(department of primary affiliation)</small>
          <br>
          <%= f.text_field :department, class: "form-control" %>
        </div>
      </div>
      <div class="col-5">
        <div class="mb-3">
          or organisation that is not already listed:
          <%= f.text_field :new_organisation_name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :country %><br />
          <%= f.country_select :country, class: "form-control",
                               :prompt => "Country..." %>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-12">
        <div class="mb-3">
          <%= f.label :other_organizations %>
          <small>(other organisations that you are affiliated with; each
          organisation on a new line)</small>
          <br>
          <%= f.text_area :other_organizations, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Contact details %>
<div class="card">
  <div class="card-header">
    <strong>Contact Details</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :google_scholar %>
          <small>(e.g. https://scholar.google.com/citations?user=you)</small>
          <br>
          <%= f.text_field :google_scholar, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :website %>
          <small>(e.g. https://www.mesophotic.org)</small><br>
          <%= f.text_field :website, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :alt_website %>
          <small>(e.g. https://www.mesophotic.org)</small><br>
          <%= f.text_field :alt_website, class: "form-control" %>
        </div>

      </div>
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :address %>
          <br>
          <%= f.text_area :address, class: "form-control", rows: 4 %>
        </div>
        <div class="mb-3">
          <%= f.label :phone %>
          <br>
          <%= f.text_field :phone, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Research interests %>
<div class="card">
  <div class="card-header">
    <strong>Research Interests</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :research_interests %>
          <small>(bio or description of research interests)</small>
          <br>
          <%= f.text_area :research_interests, class: "form-control",
                          rows: 12 %>
        </div>
      </div>
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :platforms %>
          <small>(that you have actively used in past research)</small>
          <br>
          <%= hidden_field_tag "user[platform_ids][]", "" %>
          <% for platform in Platform.find_each %>
            <div class="form-check">
              <%= check_box_tag "user[platform_ids][]", platform.id, @user.platforms.include?(platform), class: "form-check-input" %>
              <label class="form-check-label"><%= platform.description %></label>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Publications %>
<div class="card">
  <div class="card-header">
    <strong>
      Publications
      <small>(to link to your profile)</small>
    </strong>
  </div>
  <div class="card-body">
    <%= hidden_field_tag "user[publication_ids][]", "" %>
    <% for publication in Publication.where("authors LIKE ?", "%#{@user.last_name}%") %>
      <div class="form-check mb-2">
        <%= check_box_tag "user[publication_ids][]", publication.id, @user.publications.include?(publication), class: "form-check-input" %>
        <label class="form-check-label">
          <%= publication.authors %> (<%= publication.publication_year %>)
          <%= publication.title %>.
          <i><%= publication.journal.name if publication.journal %></i>
          <b><%= publication.volume %></b>:<%= publication.pages %>
        </label>
      </div>
    <% end %>
  </div>
</div>
