<%# Profile %>
<div class="card">
  <div class="card-header">
    <strong>User profile</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-7">
        <div class="row">
          <div class="col-4">
            <div class="mb-3">
              <%= f.label :title, class: 'required' %><br>
              <%= f.select :title, User::TITLES,
                           { prompt: "Title..." },
                           { class: "form-select" } %>
            </div>
          </div>
          <div class="col-8">
            <br>
            <% if current_user.try(:admin?)  %>
              <%# devise_mapping.confirmable? &&
                resource.pending_reconfirmation?
              Currently waiting confirmation for:
              <%= resource.unconfirmed_email %>
            <% else %>
              <div class="mb-3">
                <% if current_user.try(:admin?) %>
                  <%= f.check_box :editor %>
                  <%= f.label :editor %>&nbsp;&nbsp;&nbsp;
                  <%= f.check_box :admin %>
                  <%= f.label :admin %>
                <% else %>
                  <%= f.check_box :editor, disabled: true %>
                  <%= f.label :editor %>&nbsp;&nbsp;&nbsp;
                  <%= f.check_box :admin, disabled: true %>
                  <%= f.label :admin %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
        <div class="mb-3">
          <%= f.label :first_name, class: 'required' %><br>
          <%= f.text_field :first_name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :last_name, class: 'required' %><br>
          <%= f.text_field :last_name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :email , class: 'required' %><br>
          <%= f.email_field :email, class: "form-control" %>
        </div>
      </div>
      <div class="col-5">
        <div class="mb-3">
          <%= f.label :profile_picture, class: 'required' %><br>
          <div id="profile-picture-drop"
               class="rounded-3 mb-2 d-flex align-items-center justify-content-center profile-picture-drop"
               style="width: 244px; height: 244px; border: 2px dashed #dee2e6; cursor: pointer; overflow: hidden; background-color: #f8f9fa; position: relative; transition: all 0.15s ease;">
            <% if @user.profile_picture.attached? %>
              <%= image_tag @user.profile_picture.variant(resize: "300x300^", crop: "300x300+0+0"),
                            id: "profile-picture-preview",
                            style: "width: 100%; height: 100%; object-fit: cover;" %>
            <% else %>
              <div id="profile-picture-placeholder" class="text-center text-muted">
                <i class="bi bi-cloud-arrow-up" style="font-size: 2rem;"></i>
                <br><small>Drop image or click</small>
              </div>
              <img id="profile-picture-preview" style="width: 100%; height: 100%; object-fit: cover; display: none;">
            <% end %>
          </div>
          <%= f.file_field :profile_picture, class: "form-control", id: "profile-picture-input", style: "display: none;" %>
        </div>
        <script>
          (function() {
            var dropZone = document.getElementById('profile-picture-drop');
            var fileInput = document.getElementById('profile-picture-input');
            var preview = document.getElementById('profile-picture-preview');
            var placeholder = document.getElementById('profile-picture-placeholder');

            dropZone.addEventListener('click', function() { fileInput.click(); });

            dropZone.addEventListener('dragover', function(e) {
              e.preventDefault();
              dropZone.style.borderColor = '#0d6efd';
              dropZone.style.backgroundColor = '#e7f1ff';
            });

            dropZone.addEventListener('dragleave', function() {
              dropZone.style.borderColor = '#dee2e6';
              dropZone.style.backgroundColor = '#f8f9fa';
            });

            dropZone.addEventListener('drop', function(e) {
              e.preventDefault();
              dropZone.style.borderColor = '#dee2e6';
              dropZone.style.backgroundColor = '#f8f9fa';
              var files = e.dataTransfer.files;
              if (files.length > 0 && files[0].type.match('image.*')) {
                fileInput.files = files;
                showPreview(files[0]);
              }
            });

            fileInput.addEventListener('change', function() {
              if (this.files.length > 0) { showPreview(this.files[0]); }
            });

            function showPreview(file) {
              var reader = new FileReader();
              reader.onload = function(e) {
                preview.src = e.target.result;
                preview.style.display = '';
                if (placeholder) placeholder.style.display = 'none';
              };
              reader.readAsDataURL(file);
            }
          })();
        </script>
      </div>
    </div>
  </div>
</div>

<%# Affiliations %>
<div class="card">
  <div class="card-header">
    <strong>User affiliations</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-7">
        <div class="mb-3">
          <%= f.label :organisation_id %>
          <small>
            (primary organisation that you are affiliated with)
          </small>
          <br>
          <%= f.collection_select :organisation_id,
                                  Organisation.find_each,
                                  :id, :name,
                                  class: "form-control",
                                  :prompt => "Organisation..." %>
        </div>
        <div class="mb-3">
          <%= f.label :department %>
          <small>(department of primary affiliation)</small>
          <br>
          <%= f.text_field :department, class: "form-control" %>
        </div>
      </div>
      <div class="col-5">
        <div class="mb-3">
          or organisation that is not already listed:
          <%= f.text_field :new_organisation_name, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :country %><br />
          <%= f.country_select :country, class: "form-control",
                               :prompt => "Country..." %>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-12">
        <div class="mb-3">
          <%= f.label :other_organizations %>
          <small>(other organisations that you are affiliated with; each
          organisation on a new line)</small>
          <br>
          <%= f.text_area :other_organizations, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Contact details %>
<div class="card">
  <div class="card-header">
    <strong>Contact details</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :google_scholar %>
          <small>(e.g. http://scholar.google.com/citations?user=you)</small>
          <br>
          <%= f.text_field :google_scholar, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :twitter %>
          <small>(e.g. @mesophotic)</small><br>
          <%= f.text_field :twitter, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :website %>
          <small>(e.g. http://www.mesophotic.org)</small><br>
          <%= f.text_field :website, class: "form-control" %>
        </div>
        <div class="mb-3">
          <%= f.label :alt_website %>
          <small>(e.g. http://www.mesophotic.org)</small><br>
          <%= f.text_field :alt_website, class: "form-control" %>
        </div>

      </div>
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :address %>
          <br>
          <%= f.text_area :address, class: "form-control", rows: 7 %>
        </div>
        <div class="mb-3">
          <%= f.label :phone %>
          <br>
          <%= f.text_field :phone, class: "form-control" %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Research interests %>
<div class="card">
  <div class="card-header">
    <strong>Research interests</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :research_interests %>
          <small>(bio or description of research interests)</small>
          <br>
          <%= f.text_area :research_interests, class: "form-control",
                          rows: 12 %>
        </div>
      </div>
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :platforms %>
          <small>(that you have actively used in past research)</small>
          <br>
          <%= hidden_field_tag "user[platform_ids][]", "" %>
          <% for platform in Platform.find_each %>
            <div class="form-check">
              <%= check_box_tag "user[platform_ids][]", platform.id, @user.platforms.include?(platform), class: "form-check-input" %>
              <label class="form-check-label"><%= platform.description %></label>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Publications %>
<div class="card">
  <div class="card-header">
    <strong>
      Publications
      <small>(to link to your profile)</small>
    </strong>
  </div>
  <div class="card-body">
    <%= hidden_field_tag "user[publication_ids][]", "" %>
    <% for publication in Publication.where("authors LIKE ?", "%#{@user.last_name}%") %>
      <div class="form-check mb-2">
        <%= check_box_tag "user[publication_ids][]", publication.id, @user.publications.include?(publication), class: "form-check-input" %>
        <label class="form-check-label">
          <%= publication.authors %> (<%= publication.publication_year %>)
          <%= publication.title %>.
          <i><%= publication.journal.name if publication.journal %></i>
          <b><%= publication.volume %></b>:<%= publication.pages %>
        </label>
      </div>
    <% end %>
  </div>
</div>
