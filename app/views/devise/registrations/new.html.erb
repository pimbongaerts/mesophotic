<div class="row">
  <div class="col-sm-6">
    <h3 class="mb-4">Sign Up</h3>

    <%= form_for(
      resource,
      as: resource_name,
      url: registration_path(resource_name),
      html: { role: "form", autocomplete: "on" }
    ) do |f| %>

      <%= devise_error_messages! %>

      <div class="mb-3">
        <%= f.label :first_name, class: 'required' %>
        <%= f.text_field :first_name, class: "form-control",
                         autocomplete: "given-name" %>
      </div>

      <div class="mb-3">
        <%= f.label :last_name, class: 'required' %>
        <%= f.text_field :last_name, class: "form-control",
                         autocomplete: "family-name" %>
      </div>

      <div class="mb-3">
        <%= f.label :email %>
        <%= f.email_field :email, class: "form-control",
                          autocomplete: "email" %>
      </div>

      <div class="mb-3">
        <%= f.label :password %>
        <%= f.password_field :password, class: "form-control",
                             autocomplete: "new-password" %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation %>
        <%= f.password_field :password_confirmation, class: "form-control",
                             autocomplete: "new-password" %>
      </div>

      <div class="mb-3">
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
        <div class="cf-turnstile" data-sitekey="<%= Rails.application.credentials.dig(:turnstile, :site_key) %>"></div>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Sign Up", class: "btn btn-primary" %>
        <%= link_to "Sign In as an Existing Member", new_user_session_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>

  </div>
</div>
