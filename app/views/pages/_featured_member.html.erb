<% if @featured_member %>
<div>
  <%= link_to member_pages_path(@featured_member) do %>
    <div class="rounded-3 float-start me-3 mb-1" style="width: 128px; height: 128px; background-color: #f0f1f3; overflow: hidden;">
      <%= image_tag @featured_member.profile_picture.variant(resize: "128x128^", crop: "128x128+0+0"),
                    style: "width: 100%; height: 100%; object-fit: cover;" %>
    </div>
  <% end %>
  <strong><%= link_to @featured_member.full_name_normal,
                      member_pages_path(@featured_member), style: "text-decoration: none;" %></strong>
  <% if @featured_member.organisation.present? %>
    <br><small class="text-muted"><%= @featured_member.organisation.name %></small>
    <% if @featured_member.country.present? %>
      <br><small class="text-muted"><%= ISO3166::Country[@featured_member.country] %></small>
    <% end %>
  <% end %>
  <% if @featured_member.research_interests.present? %>
    <div style="margin-top: 6px;"><small style="font-size: 0.9em;"><%= truncate(@featured_member.research_interests, length: 250) %></small></div>
  <% end %>
</div>
<% end %>
