<table class="table table-sm table-striped table-hover mb-0">
  <thead>
    <tr>
      <th>Name</th>
      <th>Institution</th>
      <th>Country</th>
      <th class="text-center">Pubs</th>
      <% if current_user.try(:editor_or_admin?) %>
        <th style="width: 60px;"></th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% users.each do |user| %>
      <tr>
        <td>
          <% if user.publications.count > 0 or user.research_interests %>
            <%= link_to "#{user.first_name} <strong>#{user.last_name}</strong>".html_safe,
                        member_pages_path(user.id), style: "text-decoration: none;" %>
          <% else %>
            <%= user.first_name %> <strong><%= user.last_name %></strong>
          <% end %>
        </td>
        <td><small class="text-muted"><%= truncate(user.organisation.name, length: 30) if user.organisation %></small></td>
        <td><small class="text-muted"><%= user.organisation.country if user.organisation %></small></td>
        <td class="text-center">
          <% if user.publications.count > 0 %>
            <span class="badge bg-secondary"><%= user.publications.count %></span>
          <% end %>
        </td>
        <% if current_user.try(:editor_or_admin?) %>
          <td style="white-space: nowrap;">
            <div class="d-flex gap-2">
              <%= link_to edit_admin_user_path(user.id), class: "text-muted icon-btn" do %>
                <i class="bi bi-pencil"></i><i class="bi bi-pencil-fill"></i>
              <% end %>
              <% if current_user.try(:admin?) && current_user.id != user.id %>
                <%= link_to admin_user_path(user.id),
                            data: { turbo_method: :delete, turbo_confirm: "Delete #{user.email}? This cannot be undone." },
                            class: "text-danger icon-btn" do %>
                  <i class="bi bi-trash"></i><i class="bi bi-trash-fill"></i>
                <% end %>
              <% end %>
            </div>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
