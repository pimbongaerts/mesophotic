<%= render partial: "layouts/home_title" %>

<div class="card">
  <div class="card-body background_image d-flex align-items-center justify-content-center p-0">
    <div style="width: 100%; max-width: 700px; height: 300px;">
      <%= render_async world_map_path(key: "pages_home", model: Location, ids: @locations.map(&:id).join(','), height: 300, backgroundcolor: '#FCFFC5') %>
    </div>
  </div>
</div>


<!-- Latest news -->
<h5 class="mt-5"><strong>Latest News</strong></h5>
<div class="row mb-4">
  <% @posts.each do |post| %>
    <% cache ["post_card_small", post] do %>
      <%= render partial: 'shared/post_summary_small', locals: { post: post } %>
    <% end %>
  <% end %>
</div>

<!-- Latest publications -->
<div class="row">
  <div class="col-sm-7">
    <div class="card">
      <div class="card-header"><strong>Latest Publications</strong></div>
      <div class="card-body" style="background-color: #f8f9fa;">
        <% cache ["home_publications", @latest_update] do %>
          <%= render partial: 'newsfeed',
                     locals: { publications: @publications } %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-sm-5">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong><span style="color: #595aff;">#mesophotic</span> on Mastodon</strong>
        <%= image_tag "mastodon_logo.png", size: "16x16", style: "vertical-align: middle;" %>
      </div>
      <div class="card-body">
        <%= render_async mastodon_feed_pages_path do %>
          <div class="text-center text-muted py-4">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            Loading feed...
          </div>
        <% end %>
      </div>
      <div class="card-footer text-muted" style="font-size: 0.85em;">
        Use the <strong>#mesophotic</strong> hashtag to contribute
      </div>
    </div>
  </div>
</div>
