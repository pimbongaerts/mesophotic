<%= render partial: "layouts/home_title" %>

<div class="card">
  <div class="card-body background_image d-flex align-items-center justify-content-center p-0">
    <div style="width: 100%; max-width: 700px; height: 300px;">
      <%= turbo_frame_tag "world-map-pages_home", src: world_map_path(key: "pages_home", model: Location, ids: @locations.map(&:id).join(','), height: 300, backgroundcolor: '#FCFFC5') %>
    </div>
  </div>
</div>


<!-- Latest news -->
<h5 class="mt-5"><strong>Latest News</strong></h5>
<div class="row mb-4">
  <% @posts.each do |post| %>
    <% cache ["post_card_small", post] do %>
      <%= render partial: 'shared/post_summary_small', locals: { post: post } %>
    <% end %>
  <% end %>
</div>

<!-- Latest publications -->
<div class="row">
  <div class="col-sm-7">
    <div class="card">
      <div class="card-header"><strong>Latest Publications</strong></div>
      <div class="card-body" style="background-color: #f8f9fa;">
        <% cache ["home_publications", @latest_update] do %>
          <%= render partial: 'newsfeed',
                     locals: { publications: @publications } %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-sm-5">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <strong><span id="feed-hashtag" style="color: #0085ff;">#mesophotic</span> <span id="feed-platform">on Bluesky</span></strong>
        </div>
        <div class="d-flex align-items-center gap-2">
          <a href="#" id="tab-bluesky" onclick="switchFeed('bluesky'); return false;" title="Bluesky">
            <i class="bi bi-bluesky" style="font-size: 1.1rem; color: #0085ff;" id="logo-bluesky"></i>
          </a>
          <a href="#" id="tab-mastodon" onclick="switchFeed('mastodon'); return false;" title="Mastodon">
            <i class="bi bi-mastodon" style="font-size: 1.1rem; color: #adb5bd;" id="logo-mastodon"></i>
          </a>
        </div>
      </div>
      <div class="card-body">
        <div id="feed-mastodon" style="display: none;">
          <%= turbo_frame_tag "mastodon-feed", src: mastodon_feed_pages_path do %>
            <div class="text-center text-muted py-4">
              <div class="spinner-border spinner-border-sm me-2" role="status"></div>
              Loading feed...
            </div>
          <% end %>
        </div>
        <div id="feed-bluesky">
          <%= turbo_frame_tag "bluesky-feed", src: bluesky_feed_pages_path do %>
            <div class="text-center text-muted py-4">
              <div class="spinner-border spinner-border-sm me-2" role="status"></div>
              Loading feed...
            </div>
          <% end %>
        </div>
      </div>
      <div class="card-footer text-muted" style="font-size: 0.85em;">
        Use the <strong>#mesophotic</strong> hashtag to contribute
      </div>
    </div>
  </div>
</div>
