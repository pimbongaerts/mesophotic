<% if @publication.authors %>
  <div class="card">
    <div class="card-header">
      <strong>Users linked to publication</strong>
    </div>
    <div class="card-body">
      <%= f.label :user %> <small class="text-muted">(list automatically generated)</small>
      <% for author in @publication.authors.split(', ') %>
        <% last_name = author.split()[0] %>
        <%= hidden_field_tag "publication[user_ids][]", "" %>
        <% for user in User.where(:last_name => last_name) %>
          <div class="form-check">
            <%= check_box_tag "publication[user_ids][]", user.id,
                              @publication.users.include?(user), class: "form-check-input" %>
            <label class="form-check-label"><%= user.first_name %> <%= user.last_name %></label>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="card">
  <div class="card-header">
    <strong>Publication metadata</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-6">
        <div class="mb-3">
          <%= f.label :min_depth %><br>
          <%= f.text_field :min_depth,
              class: "form-control monospaced-control",
              placeholder: "10" %>
        </div>
        <div class="mb-3">
          <%= f.label :max_depth %><br>
          <%= f.text_field :max_depth,
                           class: "form-control monospaced-control",
                           placeholder: "40" %>
        </div>
      </div>
      <div class="col-6">
        <div class="form-check mb-2">
          <%= f.check_box :mesophotic, class: "form-check-input" %>
          <%= f.label "Mesophotic", class: "form-check-label" %>
          <br><small class="text-muted">(presents data from or discusses the mesophotic depth range)</small>
        </div>
        <div class="form-check mb-2">
          <%= f.check_box :mce, class: "form-check-input" %>
          <%= f.label "Mesophotic Coral Ecosystem", class: "form-check-label" %>
          <br><small class="text-muted">(mesophotic coral reef ecosystem; should also have "mesophotic")</small>
        </div>
        <div class="form-check mb-2">
          <%= f.check_box :tme, class: "form-check-input" %>
          <%= f.label "Temperate Mesophotic Ecosystem", class: "form-check-label" %>
          <br><small class="text-muted">(temperate mesophotic ecosystem; should also have "mesophotic")</small>
        </div>
        <div class="form-check mb-2">
          <%= f.check_box :original_data, class: "form-check-input" %>
          <%= f.label :original_data, class: "form-check-label" %>
          <br><small class="text-muted">(publication documents original data)</small>
        </div>
        <div class="form-check mb-2">
          <%= f.check_box :new_species, class: "form-check-input" %>
          <%= f.label :new_species, class: "form-check-label" %>
          <br><small class="text-muted">(publication describes new species)</small>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-3">
        <%= f.label :platform %>
        <%= hidden_field_tag "publication[platform_ids][]", "" %>
        <% for platform in Platform.all.order("LOWER(description) ASC") %>
          <div class="form-check">
            <%= check_box_tag "publication[platform_ids][]", platform.id,
                              @publication.platforms.include?(platform), class: "form-check-input" %>
            <label class="form-check-label"><%= platform.description %>
              <% wc = count_word_in_contents(platform.description, @publication.contents) %>
              <% if wc.present? %><small class="text-muted">(<%= wc %>)</small><% end %>
            </label>
          </div>
        <% end %>
      </div>

      <div class="col-3">
        <%= f.label :field %>
        <%= hidden_field_tag "publication[field_ids][]", "" %>
        <% for field in Field.all.order("LOWER(description) ASC") %>
          <div class="form-check">
            <%= check_box_tag "publication[field_ids][]", field.id,
                              @publication.fields.include?(field), class: "form-check-input" %>
            <label class="form-check-label"><%= field.description %>
              <% wc = count_word_in_contents(field.description, @publication.contents) %>
              <% if wc.present? %><small class="text-muted">(<%= wc %>)</small><% end %>
            </label>
          </div>
        <% end %>
      </div>

      <div class="col-3">
        <%= f.label :focusgroup %>
        <%= hidden_field_tag "publication[focusgroup_ids][]", "" %>
        <% for focusgroup in Focusgroup.all.order("LOWER(description) ASC") %>
          <div class="form-check">
            <%= check_box_tag "publication[focusgroup_ids][]", focusgroup.id,
                              @publication.focusgroups.include?(focusgroup), class: "form-check-input" %>
            <label class="form-check-label"><%= focusgroup.description %>
              <% wc = count_word_in_contents(focusgroup.description, @publication.contents) %>
              <% if wc.present? %><small class="text-muted">(<%= wc %>)</small><% end %>
            </label>
          </div>
        <% end %>
      </div>

      <div class="col-3">
        <%= f.label :location %>
        <%= hidden_field_tag "publication[location_ids][]", "" %>
        <% for location in Location.all.order("LOWER(description) ASC") %>
          <div class="form-check">
            <%= check_box_tag "publication[location_ids][]", location.id,
                              @publication.locations.include?(location), class: "form-check-input" %>
            <label class="form-check-label"><%= location.description %></label>
          </div>
        <% end %>
      </div>

    </div>

  </div>
</div>


