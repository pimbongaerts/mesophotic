<%= form_tag(publications_path, :method => "get", id: "search-form") do %>
  <div class="card">
    <div class="card-header">
      <strong>Search Full Publication Text</strong>
    </div>
    <div class="card-body">
      <div class="row align-items-start">
        <div class="col-sm-6">
          <%= text_field_tag :search, params[:search], class: "form-control",
                             placeholder: "Search Publications" %>
        </div>
        <% if current_user.try(:editor_or_admin?) %>
          <div class="col-sm-2">
            <%= select_tag :validation_type,
                options_for_select(
                  Validation::VALIDATION_TYPES
                    .map { |a| a.gsub("_", " ") }
                    .zip(Validation::VALIDATION_TYPES),
                  params[:validation_type]
                ),
                class: "form-select" %>
          </div>
        <% end %>
        <div class="col-sm-4 d-flex align-items-start gap-2">
          <%= submit_tag "Search", class: "btn btn-primary" %>
          <%= link_to "Reset", publications_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
      <div class="row">
        <div class="col-sm-12 search horizontal">
          <%= search_param "", Publication::PUBLICATION_SEARCH_FIELDS, :search_fields, params %>
        </div>
      </div>
    </div>
    <a data-bs-toggle="collapse" href="#collapse1" class="card-footer text-center text-muted d-block" style="text-decoration: none; font-size: 0.85em; cursor: pointer;">
      <i class="bi bi-sliders me-1"></i>Advanced Filters
    </a>
    <div id="collapse1" class="<%= (Publication.should_show_advanced params[:search_params]) ? "collapse search" : "collapse search"%>">
      <div class="card-body">
        <div class="row">
          <div class="col-sm-12">
            <% 
              year_range = params.dig(:search_params, :year_range) || "#{Publication.min_year},#{Publication.max_year}"
            %>
            <%= dual_range_slider('search_params[year_range]', {
              min: Publication.min_year,
              max: Publication.max_year,
              step: 1,
              value: year_range,
              id: 'year_slider'
            }) %>
          </div>
        </div>
        <div class="row">
          <div class="col-sm-12">
            <% 
              depth_range = params.dig(:search_params, :depth_range) || "0,500"
            %>
            <%= dual_range_slider('search_params[depth_range]', {
              min: 0,
              max: 500,
              step: 5,
              value: depth_range,
              id: 'depth_slider',
              suffix: 'm',
              max_label: '500m+'
            }) %>
          </div>
        </div>
        <div class="row">
          <hr>
          <div class="col-sm-3">
            <%= search_param "Types", Publication::PUBLICATION_TYPES, :types, params %>
          </div>
          <div class="col-sm-3">
            <%= search_param "Formats", Publication::PUBLICATION_FORMATS, :formats, params %>
          </div>
          <div class="col-sm-3">
            <%= search_param "Characteristics", Publication.publication_characteristics, :characteristics, params %>
          </div>
        </div>
        <div class="row">
          <hr>
          <div class="col-sm-6">
            <%= search_param "Locations", Publication.publication_locations, :locations, params, true %>
          </div>
          <div class="col-sm-6">
            <%= search_param "Focus Groups", Publication.publication_focusgroups, :focusgroups, params, true %>
          </div>
        </div>
        <div class="row"><br></div>
        <div class="row">
          <div class="col-sm-6">
            <%= search_param "Platforms", Publication.publication_platforms, :platforms, params, true %>
          </div>
          <div class="col-sm-6">
            <%= search_param "Academic Fields", Publication.publication_fields, :fields, params, true %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
