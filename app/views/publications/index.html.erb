<% supertitle = "Editor Mode" if current_user.try(:editor_or_admin?) %>
<% subtitle = "Search results for: '#{params[:search]}'" if params[:search] %>
<%= render partial: "layouts/page_title",
       locals: { title: "Publications",
                 subtitle: subtitle,
                 supertitle: supertitle,
                 breadcrumbs: [["Publications", nil]] } %>

<%# Wide screen for search results or editor view %>
<% sidebar = !(params[:search].present? || current_user.try(:editor_or_admin?)) %>
<div class='row'>
  <% if sidebar %>
    <div class="col-sm-8">
  <% else %>
    <div class="col-sm-12">
  <% end %>

  <%# Temporary message at top of page %>
  <div class="p-3 rounded mb-3" style="background-color: #fff9e6; font-size: 0.9em;">
    We are currently undertaking a large effort to bring the Mesophotic.org database up-to-date. If you have published any
    scientific papers that are not currently listed, please add them to this <a href="https://tinyurl.com/mesopubs">Google Sheet</a>.
  </div>

  <%# Search field and pagination %>
  <%= render 'search_field' %>

  <div class="mb-3">
    <%= paginate @publications %>
    <div style="margin-top: -0.5rem;">
      <small class="text-muted"><%= @publications.total_count %> results</small>
      <small>&bullet; <%= link_to "Download as CSV", publications_path(format: :csv, params: params.permit!) %></small>
      <% if current_user.try(:editor_or_admin?) %>
        <small class="text-muted">· sorted by ID desc</small>
      <% end %>
    </div>
    <% if (current_user.try(:editor_or_admin?) || false) && params[:validation_type] == 'all_expired' %>
      <%= button_to "Revalidate All",
                    touch_validations_publications_path(ids: @publications.map(&:id)),
                    method: "post",
                    class: "btn btn-warning btn-sm ms-2" %>
    <% end %>
  </div>

  <%# Render publications %>
  <% if current_user.try(:editor_or_admin?) %>
    <table class="table table-sm align-top table-borderless pub-editor-table">
      <% @publications.each_with_index do |publication, idx| %>
        <%= render partial: "publication_validation",
                   locals: { publication: publication, idx: idx } %>
      <% end %>
    </table>
  <% else %>
    <div class="card">
      <div class="card-body" style="background-color: #f8f9fa;">
        <%= render partial: 'pages/newsfeed', locals: { publications: @publications } %>
      </div>
    </div>
  <% end %>

  <div>
    <div class="mb-2">
      <small class="text-muted"><%= @publications.total_count %> results</small>
      <small>&bullet; <%= link_to "Download as CSV", publications_path(format: :csv, params: params.permit!) %></small>
    </div>
    <%= paginate @publications %>
  </div>
</div>

<%# Right column (only visible when not searching/editor ) %>
<% if sidebar %>
  <div class="col-sm-4">

    <%= render partial: 'featured_pub' %>

    <div class="card">
      <div class="card-header"><strong>Locations</strong></div>
      <div class="card-body" align="center" style="min-height: 150px;">
        <%= render_async world_map_path(key: "publications_index", model: Location, ids: @locations, height: 150) %>
      </div>
    </div>
    <% cache ["publications_sidebar_focus", Publication.maximum(:updated_at)] do %>
    <div class="card">
      <div class="card-header"><strong>Research Focus</strong></div>
      <div class="card-body" align="center">
        <%= render partial: 'shared/bar_graph',
                   locals: { title: 'Focus',
                             categories: @focusgroups.map(&:short_chart_description),
                             occurrences: @focusgroups.map(&:count),
                             height: 200,
                             unit: "Publications" } %>
      </div>
    </div>
    <% end %>
    <% cache ["publications_sidebar_fields", Publication.maximum(:updated_at)] do %>
    <div class="card">
      <div class="card-header"><strong>Fields</strong></div>
      <div class="card-body" align="center">
        <%= render partial: 'shared/bar_graph',
                   locals: { title: 'Fields',
                             categories: @fields.map(&:short_chart_description),
                             occurrences: @fields.map(&:count),
                             height: 200,
                             unit: "Publications" } %>
      </div>
    </div>
    <% end %>
    <% cache ["publications_sidebar_platforms", Publication.maximum(:updated_at)] do %>
    <div class="card">
      <div class="card-header"><strong>Research Platforms</strong></div>
      <div class="card-body" align="center">
        <%= render partial: 'shared/bar_graph',
                   locals: { title: 'Platforms',
                             categories: @platforms.map(&:short_chart_description),
                             occurrences: @platforms.map(&:count),
                             height: 200,
                             unit: "Publications" } %>
      </div>
    </div>
    <% end %>
  </div>
<% end %>
</div>
