<% title("Admin") %>
<%= render partial: 'shared/breadcrumbs', locals: { breadcrumbs: [["Admin", nil]] } %>
<h3>Admin</h3>

<div class="row mb-4">
  <div class="col-sm-4">
    <div class="card text-center mb-0">
      <div class="card-body">
        <h2 class="mb-0"><%= @count %></h2>
        <small class="text-muted">Users</small>
      </div>
      <div class="card-footer">
        <%= link_to "Manage users", admin_users_path %>
      </div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card text-center mb-0">
      <div class="card-body">
        <h2 class="mb-0"><%= @publication_count %></h2>
        <small class="text-muted">Publications</small>
      </div>
      <div class="card-footer">
        <%= link_to "Manage publications", dashboard_admin_publications_path %>
      </div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card text-center mb-0">
      <div class="card-body">
        <h2 class="mb-0"><%= @post_count %></h2>
        <small class="text-muted">Posts</small>
      </div>
      <div class="card-footer">
        <%= link_to "Manage posts", admin_posts_path %>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-sm-6">
    <div class="card">
      <div class="card-header"><strong>Recent Sign Ups</strong></div>
      <div class="card-body">
        <% @last_signups.each do |user| %>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <%= link_to user.email, edit_admin_user_path(user), style: "text-decoration: none;" %>
            <small class="text-muted"><%= time_ago_in_words(user.created_at) %> ago</small>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-sm-6">
    <div class="card">
      <div class="card-header"><strong>Recent Sign Ins</strong></div>
      <div class="card-body">
        <% @last_signins.each do |user| %>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <%= link_to user.email, edit_admin_user_path(user), style: "text-decoration: none;" %>
            <small class="text-muted">
              <% if user.last_sign_in_at %>
                <%= time_ago_in_words(user.last_sign_in_at) %> ago
              <% else %>
                never
              <% end %>
            </small>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="mt-3">
  <small class="text-muted"><strong>Switch user:</strong> <%= switch_user_select %></small>
</div>
