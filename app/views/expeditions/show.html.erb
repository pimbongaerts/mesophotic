<%= render partial: "layouts/page_title",
       locals: {title: "Expeditions",
                subtitle: "#{@expedition.title}",
                backlink: expeditions_path } %>

<div class="row">
  <div class="col-sm-12">
    <div class="card">
      <div class="card-body" style="background: #CCCCCC;">
        <div class="col-sm-6">
          <% if @expedition.featured_image.attached? %>
            <div style="background-color: #f0f1f3;">
              <%= image_tag @expedition.featured_image.variant(resize: "640x480>"), style: "width: 100%;" %>
            </div>
            <% if @expedition.featured_image_credits? %>
              <small>
                (C) <%= @expedition.featured_image_credits %>
              </small>
            <% end %>
          <% end %>
        </div>
        <div class="col-sm-4">
          <p><strong>
            Expedition | <%= @expedition.start_date.year %>
          </strong></p>
          <h2><%= @expedition.title %></h2>
        </div>
        <div class="col-sm-2" align="right">

        </div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-sm-8">
    <div class="card">
      <div class="card-header"><strong>Expedition Description</strong></div>
      <div class="card-body">
        <p><%= @expedition.description %></p>
      </div>
    </div>
  </div>

  <div class="col-sm-4">

    <div class="card">
      <div class="card-header"><strong>Institutions / Members</strong></div>
      <div class="card-body">
        <strong>Institutions</strong><br>
        <% @expedition.organisations.each do |organisation| %>
          <%= organisation.name %>
          <br>
        <% end %>
        <br>
        <strong>Members involved</strong><br>
        <% @expedition.users.each do |user| %>
          <%= link_to "#{user.first_name} #{user.last_name}",
                      member_pages_path(user.id) %>
          <br>
        <% end %>
      </div>
      <div class="card-footer">Listed in alphabetical order</div>
    </div>

    <div class="card">
      <div class="card-header"><strong>Expedition Metadata</strong></div>
      <div class="card-body">
        <%= render partial: 'shared/metadata',
                   locals: { entity: @expedition } %>
      </div>
    </div>

    <% if @expedition.posts.count > 1 %>
      <div class="card">
        <div class="card-header"><strong>Expedition Posts</strong></div>
        <div class="card-body">

        </div>
      </div>
    <% end %>
  </div>

</div>


<%= link_to 'Edit', edit_expedition_path(@expedition) %> |
<%= link_to 'Back', expeditions_path %>

